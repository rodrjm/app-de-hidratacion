# URL base del backend (sin /api al final, el cliente ya añade /api).
# En dispositivo/emulador usa la IP de tu PC en la red, no localhost.
# Ejemplo: EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api

# Google OAuth Client ID (obtener desde Google Cloud Console)
# Ejemplo: EXPO_PUBLIC_GOOGLE_CLIENT_ID=75000472458-uke3ativnm3gf8fs6nq740hton8llls3.apps.googleusercontent.com

# (Opcional) App IDs de AdMob – no se suben al repo si solo los pones en .env
# Si no los defines, la app usará los IDs de prueba de Google.
# EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXX~YYYYYYYY
# EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXX~YYYYYYYY

# (Opcional) Unit IDs de banners AdMob
# EXPO_PUBLIC_ADMOB_BANNER_FOOTER=ca-app-pub-3940256099942544/6300978111
# EXPO_PUBLIC_ADMOB_BANNER_DASHBOARD=ca-app-pub-3940256099942544/6300978111
# EXPO_PUBLIC_ADMOB_BANNER_PROFILE=ca-app-pub-3940256099942544/6300978111
